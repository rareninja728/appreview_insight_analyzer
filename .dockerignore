data/raw/*
data/processed/*
outputs/weekly_notes/*
outputs/email_drafts/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!outputs/weekly_notes/.gitkeep
!outputs/email_drafts/.gitkeep

# Ignore DBs and Logs
*.sqlite3
scheduler.log
